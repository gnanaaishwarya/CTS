Product.java

import java.util.ArrayList;
import java.util.List;

public class Main {
    public static void main(String[] args) {
        // Create an inventory list to hold products
        List<Product> inventory = new ArrayList<>();

        // Initialize and add product instances
        Product prod1 = new Product(101, "Wireless Mouse", 50, 24.99);
        Product prod2 = new Product(102, "Mechanical Keyboard", 30, 79.99);
        Product prod3 = new Product(103, "Gaming Monitor", 15, 299.50);

        inventory.add(prod1);
        inventory.add(prod2);
        inventory.add(prod3);

        // Print initial inventory using the toString() method
        System.out.println("--- Current Inventory ---");
        for (Product p : inventory) {
            System.out.println(p);
        }

        // Update product stock and price using setter methods
        System.out.println("\n--- Updating Inventory ---");
        prod1.setQuantity(45); // 5 mice sold
        prod2.setPrice(69.99); // Keyboard put on sale

        // Access specific details using getter methods
        System.out.println("Updated " + prod1.getProductName() + " stock: " + prod1.getQuantity());
        System.out.println("Updated " + prod2.getProductName() + " price: $" + prod2.getPrice());
    }
}


InventoryManager Class
import java.util.HashMap;

public class InventoryManager {

    private HashMap<Integer, Product> inventory =
            new HashMap<>();

    // Add Product
    public void addProduct(Product product) {
        inventory.put(product.getProductId(), product);
        System.out.println("Product Added Successfully");
    }

    // Update Product
    public void updateProduct(int productId,
                              int quantity,
                              double price) {

        Product product = inventory.get(productId);

        if (product != null) {
            product.setQuantity(quantity);
            product.setPrice(price);
            System.out.println("Product Updated Successfully");
        } else {
            System.out.println("Product Not Found");
        }
    }

    // Delete Product
    public void deleteProduct(int productId) {

        if (inventory.remove(productId) != null) {
            System.out.println("Product Deleted Successfully");
        } else {
            System.out.println("Product Not Found");
        }
    }

    // Display Inventory
    public void displayInventory() {
        for (Product product : inventory.values()) {
            System.out.println(product);
        }
    }
}


Main Class
public class Main {

    public static void main(String[] args) {

        InventoryManager manager =
